# ======================================
# Authentication
# ======================================
# Generate with: bunx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ======================================
# AI Provider
# ======================================
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ======================================
# Database
# ======================================
# Local Docker: postgresql://farasa_user:farasa_password@localhost:5433/farasa_db
# Cloud (Neon): postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ======================================
# Search
# ======================================
# https://app.tavily.com/home — format starts with tvly-
TAVILY_API_KEY=

# ======================================
# Google Cloud Storage
# ======================================
# https://console.cloud.google.com/storage
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
# Local dev only — on Cloud Run, use attached service account (no env var needed)
GOOGLE_APPLICATION_CREDENTIALS=

# ======================================
# App Runtime
# ======================================
NEXT_PUBLIC_APP_URL=http://localhost:3010
APP_PORT=3010

# Auth.js callback URLs
AUTH_URL=http://localhost:3010
NEXTAUTH_URL=http://localhost:3010

# ======================================
# Runtime Config (optional — schema provides defaults from SSOT constants)
# ======================================
# Override specific values via JSON partial. DB rows override env, user overrides tenant.
RUNTIME_CONFIG_JSON=
RUNTIME_CONFIG_CACHE_TTL_MS=

# ======================================
# Build / Node
# ======================================
NODE_ENV=development
