# Auth.js v5 — https://authjs.dev/getting-started/installation
# Generate with: bunx auth secret
AUTH_SECRET=

# Google Cloud Console → APIs & Services → OAuth 2.0 Client IDs
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Neon Postgres — https://neon.tech/docs/connect/connect-intro
# Format: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Tavily — https://app.tavily.com/home (API Keys tab)
# Format starts with: tvly-
TAVILY_API_KEY=

# Google Cloud Storage
# Create bucket at: https://console.cloud.google.com/storage
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
# Local dev only — on Cloud Run, use attached service account (no env var needed)
GOOGLE_APPLICATION_CREDENTIALS=

# App URL — used for OpenRouter HTTP-Referer header and Auth.js callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set automatically by Next.js / deployment platform
NODE_ENV=development
