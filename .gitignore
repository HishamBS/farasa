# Local hidden directories — ignore by default
.*/
*.md
!README.md
# Repository-managed hidden directories
!.github/
!.github/**
!.husky/
!.husky/**

.DS_Store

# Dependencies
node_modules/

# Build outputs
.next/
out/
dist/
build/
# Serwist generated service worker
/public/sw.js
/public/sw.js.map

# Environment variables — never commit
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Drizzle Studio cache only (migration files are committed)
drizzle/.drizzle-studio/

# Logs
*.log
bun-error.log*

# Internal QA artifacts (local-only)
*QA*.md
*qa*.md
docs/qa-*/
docs/*qa*/
playwright-report/
test-results/
traces/
screenshots/
videos/
*.har
*.trace
*.webm
tmp-qa/

# TypeScript build cache
tsconfig.tsbuildinfo
*.tsbuildinfo


# Misc
*.pem
.vercel
