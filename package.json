{
  "name": "farasa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DISABLE_WEBPACK_CACHE=1 NEXT_PRIVATE_BUILD_WORKER=0 node node_modules/next/dist/bin/next dev -p 3010",
    "build": "NEXT_DISABLE_WEBPACK_CACHE=1 NEXT_PRIVATE_BUILD_WORKER=0 node node_modules/next/dist/bin/next build",
    "start": "NEXT_PRIVATE_BUILD_WORKER=0 node node_modules/next/dist/bin/next start",
    "type-check": "next typegen && tsc --noEmit",
    "lint": "next lint && bun run lint:ssot-literals",
    "lint:ssot-literals": "node scripts/enforce-ssot-literals.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:squash": "rm -rf ./drizzle && drizzle-kit generate --name=initial_schema",
    "db:reset": "docker compose -f docker/docker-compose.dev.yml down -v && docker compose -f docker/docker-compose.dev.yml up -d postgres && sleep 3 && bun run db:squash && bun run db:migrate"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,css,md,mjs,sh}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@a2ui-sdk/react": "0.4.0",
    "@a2ui-sdk/types": "0.4.0",
    "@a2ui-sdk/utils": "0.4.0",
    "@auth/drizzle-adapter": "^1.4.0",
    "@google-cloud/storage": "^7.11.2",
    "@neondatabase/serverless": "^0.9.4",
    "@openrouter/sdk": "0.9.11",
    "@serwist/next": "^9.0.9",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-virtual": "^3.10.8",
    "@tavily/core": "^0.3.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "framer-motion": "^11.3.8",
    "fuse.js": "^7.1.0",
    "geist": "^1.3.0",
    "katex": "^0.16.11",
    "lucide-react": "^0.575.0",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.22",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "serwist": "^9.0.9",
    "shiki": "^1.10.3",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "hono": ">=4.12.4",
    "@hono/node-server": ">=1.19.10",
    "express-rate-limit": ">=8.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/types": "^20.4.0",
    "@eslint/eslintrc": "^3.3.4",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bun": "^1.2.22",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.14.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "postcss": "^8.4.39",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.5.3"
  }
}
